# Database
MYSQL_ROOT_PASSWORD=change-me

# Frontend
GEMINI_API_KEY=your-gemini-api-key
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Frontend - Cloudflare Turnstile (login/register)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# Backend - Google OAuth (same Client ID for token verification)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Backend - JWT
JWT_SECRET=your-jwt-secret
JWT_REFRESH_SECRET=your-jwt-refresh-secret

# Backend - S3-Compatible Storage (S3Cloud VN)
R2_ENDPOINT_URL=https://s3-hcm-r2.s3cloud.vn
R2_ACCESS_KEY=your-s3-access-key
R2_SECRET_KEY=your-s3-secret-key
R2_BUCKET=lawzy
R2_REGION=hcm

# Backend payOS — register webhook on my.payos.vn → {API_PUBLIC_URL}/payments/webhook
# Docs: https://payos.vn/docs/api/
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
# PAYOS_BASE_URL=https://api-merchant.payos.vn
FRONTEND_URL=http://localhost:3000
