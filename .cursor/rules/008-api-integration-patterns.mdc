## Pattern 3: Custom Hooks for Data Fetching

**Location**: `src/hooks/use*.ts`

**Purpose**: Manage data fetching, loading, error states

**Structure**:

```typescript
// src/hooks/useBooks.ts
import { useState, useEffect, useCallback } from 'react';
import { bookService } from '@/core/services/api/books.service';
import type { Book, BookFilters } from '@/core/services/api/types/book.types';
import type { PaginatedResponse } from '@/core/services/api/types/api-response';

interface UseBooksReturn {
  books: Book[];
  loading: boolean;
  error: Error | null;
  pagination: {
    currentPage: number;
    totalPages: number;
    total: number;
  } | null;
  refetch: () => Promise<void>;
}

export const useBooks = (filters?: BookFilters): UseBooksReturn => {
  const [books, setBooks] = useState<Book[]>([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<Error | null>(null);
  const [pagination, setPagination] = useState<UseBooksReturn['pagination']>(null);

  const fetchBooks = useCallback(async () => {
    try {
      setLoading(true);
      setError(null);
      
      const response = await bookService.getAll(filters);
      
      setBooks(response.data);
      setPagination({
        currentPage: response.meta.current_page,
        totalPages: response.meta.last_page,
        total: response.meta.total,
      });
    } catch (err) {
      setError(err instanceof Error ? err : new Error('Failed to fetch books'));
      console.error('Error fetching books:', err);
    } finally {
      setLoading(false);
    }
  }, [filters]);

  useEffect(() => {
    fetchBooks();
  }, [fetchBooks]);

  return {
    books,
    loading,
    error,
    pagination,
    refetch: fetchBooks,
  };
};
```

**Best Practices**:
- ✅ Return loading, error, data, and actions
- ✅ Use `useCallback` for refetch function
- ✅ Handle errors gracefully
- ✅ Reset error state on retry
- ✅ Debounce/throttle if filters change frequently
- ❌ Don't include UI logic (toast notifications)
- ❌ Don't manage global state here (use Redux for that)

