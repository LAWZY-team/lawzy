## Pattern 2: Type Definitions

**Location**: `src/core/services/api/types/*.types.ts`

**Purpose**: Type safety for API contracts

**Structure**:

```typescript
// src/core/services/api/types/book.types.ts

/**
 * Book entity from backend
 */
export interface Book {
  id: string;
  isbn: string;
  title: string;
  author: string;
  publisher: string;
  publishedYear: number;
  coverImage: string | null;
  status: BookStatus;
  createdAt: string;
  updatedAt: string;
}

/**
 * Book status enum
 */
export type BookStatus = 'available' | 'borrowed' | 'maintenance' | 'lost';

/**
 * Create book DTO (frontend → backend)
 */
export interface CreateBookDTO {
  isbn: string;
  title: string;
  author: string;
  publisher: string;
  publishedYear: number;
  quantity: number;
}

/**
 * Update book DTO
 */
export interface UpdateBookDTO extends Partial<CreateBookDTO> {
  status?: BookStatus;
}

/**
 * Book filters for list query
 */
export interface BookFilters {
  page?: number;
  perPage?: number;
  search?: string;
  status?: BookStatus;
  sortField?: 'title' | 'author' | 'publishedYear' | 'createdAt';
  sortDirection?: 'asc' | 'desc';
}
```

**Best Practices**:
- ✅ Match backend DTOs (but use camelCase in frontend)
- ✅ Separate read types (Book) and write types (CreateBookDTO)
- ✅ Use TypeScript enums or union types for status
- ✅ Document fields with JSDoc
- ❌ Don't define types in component files
- ❌ Don't use `any` type

