## Example: Complete Flow

```typescript
// 1. Define types
// src/core/services/api/types/borrow.types.ts
export interface Borrow {
  id: string;
  bookId: string;
  userId: string;
  borrowedAt: string;
  dueDate: string;
  returnedAt: string | null;
  status: 'active' | 'returned' | 'overdue';
}

// 2. Create service
// src/core/services/api/borrows.service.ts
export const borrowService = {
  async getAll(): Promise<Borrow[]> {
    const response = await apiRequest.get('/borrows');
    return response.data;
  },
};

// 3. Create hook
// src/hooks/useBorrows.ts
export const useBorrows = () => {
  const [borrows, setBorrows] = useState<Borrow[]>([]);
  const [loading, setLoading] = useState(true);
  
  useEffect(() => {
    borrowService.getAll()
      .then(setBorrows)
      .catch(console.error)
      .finally(() => setLoading(false));
  }, []);
  
  return { borrows, loading };
};

// 4. Use in component
// src/components/BorrowList.tsx
const BorrowList = () => {
  const { borrows, loading } = useBorrows();
  
  if (loading) return <Spinner />;
  
  return (
    <div>
      {borrows.map(borrow => (
        <BorrowCard key={borrow.id} borrow={borrow} />
      ))}
    </div>
  );
};
```

**Result**: Clean separation of concerns, type-safe, testable, maintainable.
