# Tùy chọn: sao chép thành .env.docker (gitignored) và thêm vào compose env_file nếu cần.
# Chỉ dùng khi MySQL chạy trên máy host (vd. compose.dev.yml) — thay localhost bằng host.docker.internal.
# Nếu DATABASE_URL trỏ tới MySQL production trên cloud, đặt URL đó trực tiếp trong backend/.env (một file là đủ).
DATABASE_URL="mysql://root:YOUR_PASSWORD@host.docker.internal:3307/lawzy"
