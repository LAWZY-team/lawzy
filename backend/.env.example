# Sao chép thành .env và điền giá trị thật.
# Docker local backend: docker compose -f docker/compose.local-backend.yml up
# (xem docker/README.md — DATABASE_URL có thể trỏ production MySQL).

PORT=5000
FRONTEND_URL=http://localhost:3000

# MySQL — production hoặc dev. Trong Docker, nếu DB trên máy host Windows dùng host.docker.internal thay vì localhost.
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/lawzy"

JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me

# S3-compatible (Cloudflare R2, s3cloud.vn, …). URL đầy đủ có https://, không có slash cuối.
R2_ENDPOINT_URL=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=lawzy
R2_REGION=hcm
# Tuỳ chọn: retry khi lỗi DNS/mạng tạm (EAI_AGAIN). Docker: nên thêm dns 8.8.8.8 trong compose.
R2_SDK_MAX_ATTEMPTS=6
R2_RETRY_ATTEMPTS=5
R2_RETRY_MS=400

# payOS (tùy chọn local)
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# Gemini — xử lý nguồn (embeddings, v.v.)
GEMINI_API_KEY=

# Crawler phapluat.gov.vn — server thiếu intermediate trong TLS; bắt buộc thêm CA (file trong repo: backend/tls/).
# Docker: compose đặt NODE_EXTRA_CA_CERTS=/app/tls/globalsign-rsa-ov-ssl-ca-2018.pem
NODE_EXTRA_CA_CERTS=
LEGAL_CRAWLER_TLS_STRICT=true
