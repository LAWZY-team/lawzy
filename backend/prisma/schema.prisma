generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String
  password     String
  avatar       String?
  roles        Json      @default("[\"user\"]")
  position     String?
  provider     String?
  providerId   String?   @unique @map("provider_id")
  isVerified   Boolean   @default(false) @map("is_verified")
  resetToken   String?   @map("reset_token")
  resetExpires DateTime? @map("reset_expires")
  otpCode      String?   @map("otp_code")
  otpExpires   DateTime? @map("otp_expires")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  refreshTokens         RefreshToken[]
  workspaceMemberships  WorkspaceMember[]
  createdDocuments      Document[]       @relation("DocumentCreator")
  createdTemplates      Template[]       @relation("TemplateCreator")
  files                 File[]
  sources               Source[]
  chatMessages          ChatMessage[]
  customFields          UserCustomField[]
  articles              Article[]
  payments              Payment[]
  userCredit            UserCredit?
  documentVersions      DocumentVersion[]

  @@map("users")
}

model Article {
  id          String    @id @default(uuid())
  type        String    // 'news' | 'policy' | 'document' | 'announcement'
  title       String
  slug        String    @unique
  excerpt     String?   @db.Text
  content     Json?
  contentText String?   @db.LongText
  coverImage  String?   @map("cover_image")
  status      String    @default("draft")
  publishedAt DateTime? @map("published_at")
  authorId    String?   @map("author_id")
  metadata    Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  author User? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([status])
  @@index([publishedAt])
  @@map("articles")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique @db.VarChar(500)
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Workspace {
  id          String   @id @default(uuid())
  name        String
  companyCode String?  @unique @map("company_code") @db.VarChar(20)
  logo        String?
  plan        String   @default("free")
  settings    Json     @default("{}")
  quotaLimits Json?    @map("quota_limits")
  aiConfig    Json?    @map("ai_config")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members        WorkspaceMember[]
  documents      Document[]
  files          File[]
  sources        Source[]
  payments       Payment[]
  customFields   WorkspaceCustomField[]
  templates      Template[]

  @@map("workspaces")
}

model WorkspaceCustomField {
  id           String   @id @default(uuid())
  workspaceId  String   @map("workspace_id")
  key          String   @db.VarChar(80)
  label        String
  defaultValue String?  @db.Text @map("default_value")
  isHidden     Boolean  @default(false) @map("is_hidden")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, key])
  @@index([workspaceId])
  @@map("workspace_custom_fields")
}

model MembershipPlan {
  id            String   @id @default(uuid())
  slug          String   @unique
  name          String
  nameEn        String?  @map("name_en")
  description   String?  @db.Text
  descriptionEn String?  @db.Text @map("description_en")
  price         Int      @default(0)
  billingCycle  String   @default("monthly") @map("billing_cycle")
  sortOrder     Int      @default(0) @map("sort_order")
  isActive      Boolean  @default(true) @map("is_active")
  isHighlighted Boolean  @default(false) @map("is_highlighted")
  contactSales  Boolean  @default(false) @map("contact_sales")
  quotaLimits   Json?    @map("quota_limits")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  payments   Payment[]

  @@map("membership_plans")
}

model Payment {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  workspaceId String   @map("workspace_id")
  planId      String   @map("plan_id")
  amount      Int
  currency    String   @default("VND")
  orderCode   String?  @unique @map("order_code")
  checkoutUrl String?  @db.Text @map("checkout_url")
  provider    String   @default("payos")
  status      String   @default("pending")
  paidAt      DateTime? @map("paid_at")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  plan      MembershipPlan  @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([workspaceId])
  @@index([status])
  @@index([orderCode])
  @@map("payments")
}

model WorkspaceMember {
  id          String   @id @default(uuid())
  workspaceId String   @map("workspace_id")
  userId      String   @map("user_id")
  role        String   @default("viewer")
  joinedAt    DateTime @default(now()) @map("joined_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@map("workspace_members")
}

model Document {
  id               String   @id @default(uuid())
  title            String
  type             String   @default("contract")
  status           String   @default("draft")
  visibility       String   @default("workspace") @db.VarChar(20) // 'private' | 'workspace'
  contentJSON      Json?    @map("content_json")
  metadata         Json?
  mergeFieldValues Json?    @map("merge_field_values")
  templateId       String?  @map("template_id")
  workspaceId      String   @map("workspace_id")
  createdBy        String   @map("created_by")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  workspace    Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator      User             @relation("DocumentCreator", fields: [createdBy], references: [id])
  template     Template?        @relation(fields: [templateId], references: [id], onDelete: SetNull)
  versions     DocumentVersion[]
  chatMessages ChatMessage[]
  files        File[]

  @@index([workspaceId])
  @@index([createdBy])
  @@index([templateId])
  @@index([visibility])
  @@map("documents")
}

model DocumentVersion {
  id          String   @id @default(uuid())
  documentId  String   @map("document_id")
  contentJSON Json?    @map("content_json")
  mergeFieldValues Json? @map("merge_field_values")
  chatCursorAt DateTime? @map("chat_cursor_at")
  label       String?
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  creator  User     @relation(fields: [createdBy], references: [id], onDelete: Restrict)

  @@index([documentId])
  @@index([createdBy])
  @@map("document_versions")
}

model Template {
  id          String   @id @default(uuid())
  title       String
  description String?  @db.Text
  category    String   @default("general")
  scope       String   @default("system")
  contentJSON Json?    @map("content_json")
  mergeFields Json?    @map("merge_fields")
  metadata    Json?
  s3Key       String?  @map("s3_key")
  fileName    String?  @map("file_name")
  fileSize    Int?     @map("file_size")
  mimeType    String?  @map("mime_type")
  workspaceId String?  @map("workspace_id")
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  documents Document[]
  creator   User?      @relation("TemplateCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([createdBy])
  @@index([workspaceId])
  @@index([scope, workspaceId])
  @@map("templates")
}

enum FileCategory {
  input_upload
  template
  export_output
}

model File {
  id          String   @id @default(uuid())
  name        String
  size        Int
  mimeType    String   @map("mime_type")
  s3Key       String   @map("s3_key")
  category    FileCategory @default(input_upload)
  documentId  String?  @map("document_id")
  userId      String   @map("user_id")
  workspaceId String   @map("workspace_id")
  createdAt   DateTime @default(now()) @map("created_at")

  document  Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([category])
  @@index([documentId])
  @@index([workspaceId])
  @@index([userId])
  @@map("files")
}

model Source {
  id              String   @id @default(uuid())
  title           String
  type            String   @default("pdf")
  status          String   @default("pending")
  scope           String   @default("workspace") // 'workspace' | 'system' | 'premium'
  s3Key           String?  @map("s3_key")
  sourceUrl       String?  @db.Text @map("source_url")
  size            Int      @default(0)
  content         String?  @db.LongText
  pageCount       Int?     @map("page_count")
  chunkCount      Int?     @map("chunk_count")
  processingError String?  @db.Text @map("processing_error")
  tags            Json?
  workspaceId     String?  @map("workspace_id")
  userId          String   @map("user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks    SourceChunk[]

  @@index([workspaceId])
  @@index([userId])
  @@index([scope])
  @@map("sources")
}

model SourceChunk {
  id         String   @id @default(uuid())
  sourceId   String   @map("source_id")
  parentId   String?  @map("parent_id")
  content    String   @db.LongText
  pageNumber Int?     @map("page_number")
  chunkIndex Int      @map("chunk_index")
  tokenCount Int      @default(0) @map("token_count")
  embedding  Json?
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  source   Source       @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  parent   SourceChunk? @relation("ChunkHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children SourceChunk[] @relation("ChunkHierarchy")

  @@index([sourceId])
  @@index([parentId])
  @@map("source_chunks")
}

model ChatMessage {
  id         String   @id @default(uuid())
  documentId String   @map("document_id")
  role       String
  content    String   @db.LongText
  metadata   Json?
  userId     String   @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([userId])
  @@map("chat_messages")
}

model ContactSubmission {
  id          String   @id @default(uuid())
  type        String   // 'sales_inquiry' | 'feedback' | 'bug_report' | 'support_request'
  name        String
  email       String
  phone       String?
  company     String?
  title       String?  // for help types
  description String   @db.Text
  status      String   @default("pending") // 'pending' | 'processed' | 'archived'
  attachments Json?    // [{ filename, s3Key }]
  userId      String?  @map("user_id") // null for public contact form
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("contact_submissions")
}

model UserCustomField {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  key          String   @db.VarChar(80)
  label        String
  defaultValue String?  @db.Text @map("default_value")
  isHidden     Boolean  @default(false) @map("is_hidden")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
  @@map("user_custom_fields")
}

model UserCredit {
  id                  String   @id @default(uuid())
  userId              String   @unique @map("user_id")
  aiCreditsUsed       Int      @default(0) @map("ai_credits_used")
  aiCreditsLimit      Int      @default(100) @map("ai_credits_limit")
  renewalStartedAt   DateTime @map("renewal_started_at")
  aiCreditsUsedToday  Int      @default(0) @map("ai_credits_used_today")
  aiCreditsUsedDate   DateTime? @map("ai_credits_used_date")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_credits")
}

model EmailTemplate {
  id          String   @id @default(uuid())
  code        String   @unique @db.VarChar(80)
  name        String   @db.VarChar(200)
  description String?  @db.Text
  subject     String   @db.VarChar(300)
  bodyHtml    String   @db.LongText @map("body_html")
  variables   Json?    // ["toName", "workspaceName", ...] - danh sách biến có thể dùng {{var}}
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([code])
  @@map("email_templates")
}
